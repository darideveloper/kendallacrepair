---
import Layout from '../layouts/Layout.astro';

// Production Guard
if (import.meta.env.PROD) {
  return Astro.redirect('/404');
}

const colors = [
  { name: 'Navy', hex: '#0C2340', class: 'bg-brand-navy', text: 'text-white' },
  { name: 'Blue', hex: '#1A6FAF', class: 'bg-brand-blue', text: 'text-white' },
  { name: 'Sky', hex: '#5DADE2', class: 'bg-brand-sky', text: 'text-brand-navy' },
  { name: 'Orange', hex: '#F76707', class: 'bg-brand-orange', text: 'text-white' },
  { name: 'Red CTA', hex: '#E03131', class: 'bg-brand-red', text: 'text-white' },
];

const logos = [
  { name: 'Horizontal Color', src: '/images/logos/logo-horizontal-color.svg', bg: 'bg-white' },
  { name: 'Horizontal White', src: '/images/logos/logo-horizontal-white.svg', bg: 'bg-brand-navy' },
  { name: 'Stacked Color', src: '/images/logos/logo-stacked-color.svg', bg: 'bg-white' },
  { name: 'Stacked White', src: '/images/logos/logo-stacked-white.svg', bg: 'bg-brand-navy' },
  { name: 'Icon Only', src: '/images/logos/logo-icon-512.svg', bg: 'bg-white', size: 'w-32' },
];
---

<Layout title="Design System | Kendall AC Repairs">
  <div class="max-w-5xl mx-auto py-12 px-6">
    <header class="mb-16 border-b border-gray-200 pb-8">
      <h1 class="text-4xl font-heading font-extrabold text-brand-navy mb-2">Design System</h1>
      <p class="text-lg text-gray-600 font-body">Branding assets and global configuration for Kendall AC Repairs.</p>
    </header>

    <!-- Colors -->
    <section class="mb-20">
      <h2 class="text-2xl font-heading font-bold text-brand-navy mb-6">Color Palette</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {colors.map((color) => (
          <div class="flex flex-col gap-2">
            <div class={`h-24 rounded-xl flex items-end p-3 ${color.class} border border-black/5`}>
              <span class={`text-[10px] font-bold uppercase tracking-wider ${color.text}`}>{color.hex}</span>
            </div>
            <div>
              <p class="text-sm font-bold text-brand-navy">{color.name}</p>
              <p class="text-xs text-gray-500 font-mono">{color.class}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Typography -->
    <section class="mb-20">
      <h2 class="text-2xl font-heading font-bold text-brand-navy mb-6">Typography</h2>
      <div class="space-y-12">
        <div class="p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-[0.2em] mb-4">Heading Font: Plus Jakarta Sans</p>
          <div class="space-y-4 font-heading text-brand-navy">
            <p class="text-5xl font-extrabold tracking-tight">Heading 1 / 800 Weight</p>
            <p class="text-4xl font-bold">Heading 2 / 700 Weight</p>
            <p class="text-3xl font-semibold">Heading 3 / 600 Weight</p>
            <p class="text-2xl font-medium">Heading 4 / 500 Weight</p>
          </div>
        </div>

        <div class="p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-[0.2em] mb-4">Body Font: DM Sans</p>
          <div class="space-y-6 font-body text-gray-700 max-w-2xl">
            <p class="text-xl leading-relaxed font-medium">
              Conectamos a los dueños de casa en Kendall con técnicos de AC licenciados y asegurados. Servicio el mismo día, estimados gratis, disponible 24/7.
            </p>
            <p class="text-base leading-7">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
            </p>
            <p class="text-sm text-gray-500 italic">
              * Used for secondary details, captions, and legal text.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Logos -->
    <section class="mb-20">
      <h2 class="text-2xl font-heading font-bold text-brand-navy mb-6">Logo Variants</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {logos.map((logo) => (
          <div class="flex flex-col gap-3">
            <div class={`p-12 rounded-2xl border border-gray-200 flex items-center justify-center min-h-[200px] ${logo.bg}`}>
              <img src={logo.src} alt={logo.name} class={logo.size || 'w-full max-w-[280px]'} />
            </div>
            <div>
              <p class="text-sm font-bold text-brand-navy">{logo.name}</p>
              <p class="text-xs text-gray-500 font-mono">{logo.src}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Future Components Placeholder -->
    <section class="opacity-50">
      <div class="py-12 border-2 border-dashed border-gray-300 rounded-3xl flex flex-center items-center justify-center text-gray-400 font-heading font-bold uppercase tracking-widest italic">
        Future Components Area
      </div>
    </section>
  </div>
</Layout>
