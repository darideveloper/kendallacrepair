---
import '../styles/global.css';
import UrgencyBanner from '../components/molecules/UrgencyBanner.astro';
import Header from '../components/organisms/Header.astro';
import Footer from '../components/organisms/Footer.astro';
import WhatsAppButton from '../components/molecules/WhatsAppButton.astro';
import ChatButton from '../components/molecules/ChatButton.astro';
import MobileCallBar from '../components/molecules/MobileCallBar.astro';
import BaseSEO from '../components/atoms/BaseSEO.astro';
import type { Lang } from '../lib/i18n/ui';
import type { PageKey } from '../lib/i18n/routes';

interface Props {
  lang: Lang;
  pageKey: PageKey;
  title?: string;
  description?: string;
}

const { 
  lang,
  pageKey,
  title,
  description
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect hints -->
    <link rel="preconnect" href="https://maps.googleapis.com" />
    <link rel="preconnect" href="https://maps.gstatic.com" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <BaseSEO {lang} {pageKey} {title} {description} />
  </head>
  <body class="font-body text-[#343a40] bg-white overflow-x-hidden antialiased">
    <UrgencyBanner {lang} />
    <Header {lang} {pageKey} />
    
    <main>
      <slot />
    </main>

    <Footer {lang} />

    <!-- Global Floating Elements -->
    <WhatsAppButton {lang} />
    <ChatButton {lang} />
    <MobileCallBar {lang} />
  </body>
</html>