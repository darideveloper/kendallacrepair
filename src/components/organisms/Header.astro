---
import clsx from 'clsx';
import Button from '../atoms/Button.astro';
import Icon from '../atoms/Icon.astro';
import LangToggle from '../molecules/LangToggle.astro';
import { SITE } from '../../constants/site';
import { useTranslations, getLocalizedPath } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';
import type { PageKey } from '../../lib/i18n/routes';

interface Props {
  lang: Lang;
  pageKey: PageKey;
  class?: string;
}

const { lang, pageKey, class: className } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: '#servicios', label: t('nav.services') },
  { href: '#como-funciona', label: t('nav.how_it_works') },
  { href: '#testimonios', label: t('nav.testimonials') },
  { href: '#faq', label: t('nav.faq') },
];

const homePath = getLocalizedPath('home', lang);
---

<header class={clsx("header sticky top-0 z-[99] bg-white py-2 border-b border-[#E9ECEF] shadow-[0_1px_3px_rgba(0,0,0,0.08)]", className)}>
  <div class="header-inner max-w-[1200px] mx-auto px-6 flex items-center justify-between">
    <a href={homePath} class="logo flex items-center" aria-label={SITE.name}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 360 80" width="180" height="40" class="h-10 md:h-12 w-auto">
        <g transform="translate(8, 8)">
          <rect x="0" y="0" width="64" height="64" rx="14" fill="#1A6FAF"/>
          <rect x="2.5" y="2.5" width="59" height="59" rx="12" fill="none" stroke="#ffffff" stroke-width="0.5" opacity="0.15"/>
          <g transform="translate(32, 32)">
            <circle cx="0" cy="0" r="4" fill="#ffffff" opacity="0.9"/>
            <path d="M0,-5.5 C8,-5.5 11,-19 3,-23 C-1,-25 -4,-20 -1.5,-17 C3,-13 3,-8 0,-5.5Z" fill="#ffffff" opacity="0.95"/>
            <path d="M0,-5.5 C8,-5.5 11,-19 3,-23 C-1,-25 -4,-20 -1.5,-17 C3,-13 3,-8 0,-5.5Z" fill="#ffffff" opacity="0.95" transform="rotate(120)"/>
            <path d="M0,-5.5 C8,-5.5 11,-19 3,-23 C-1,-25 -4,-20 -1.5,-17 C3,-13 3,-8 0,-5.5Z" fill="#ffffff" opacity="0.95" transform="rotate(240)"/>
          </g>
          <rect x="40" y="44" width="20" height="3" rx="1.5" fill="#F76707"/>
          <rect x="44" y="50" width="16" height="3" rx="1.5" fill="#F76707" opacity="0.7"/>
          <rect x="48" y="56" width="12" height="3" rx="1.5" fill="#F76707" opacity="0.4"/>
          <text x="80" y="30" font-family="'Plus Jakarta Sans', sans-serif" font-size="28" font-weight="800" letter-spacing="-0.3" fill="#0C2340">KENDALL</text>
          <text x="80" y="54" font-family="'Plus Jakarta Sans', sans-serif" font-size="17" font-weight="600" letter-spacing="4.5" fill="#64748b">AC REPAIRS</text>
          <rect x="80" y="60" width="120" height="2" rx="1" fill="#F76707"/>
        </g>
      </svg>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex gap-7 list-none">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-base font-medium text-[#495057] transition-colors hover:text-brand-blue font-body">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-right flex items-center gap-4">
      <LangToggle {lang} {pageKey} class="hidden md:flex" />
      <Button href={`tel:${SITE.phone.value}`} variant="navy" class="md:px-5 md:py-2.5">
        <Icon name="phone" size={18} slot="before" />
        <span class="hidden md:inline">{SITE.phone.display}</span>
      </Button>
      
      <button 
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-[#495057] focus:outline-none" 
        aria-label={t('nav.open_menu')}
        aria-expanded="false"
      >
        <Icon name="menu" size={24} id="menu-icon-open" />
        <Icon name="x" size={24} class="hidden" id="menu-icon-close" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div 
    id="mobile-menu" 
    class="lg:hidden fixed inset-0 z-[100] bg-white translate-x-full transition-transform duration-300 ease-in-out pt-20"
  >
    <nav class="px-6">
      <ul class="flex flex-col gap-6 list-none">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="mobile-nav-link text-xl font-bold text-[#0C2340] font-heading block border-b border-gray-100 pb-4">
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-4">
          <Button href={`tel:${SITE.phone.value}`} variant="primary" class="w-full">
            <Icon name="phone" size={20} slot="before" />
            {t('ui.call_now')}
          </Button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.contains('translate-x-0');
    
    if (isOpen) {
      mobileMenu?.classList.replace('translate-x-0', 'translate-x-full');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      toggleBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    } else {
      mobileMenu?.classList.replace('translate-x-full', 'translate-x-0');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      toggleBtn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  }

  toggleBtn?.addEventListener('click', toggleMenu);

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu?.classList.contains('translate-x-0')) {
        toggleMenu();
      }
    });
  });
</script>
