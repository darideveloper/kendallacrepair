---
import { Image } from 'astro:assets';
import clsx from 'clsx';
import StepCard from '../molecules/StepCard.astro';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';
import bgImg from '../../assets/images/hero/foto-trane-single.webp';

interface Step {
  title: string;
  description: string;
  time?: string;
  badge?: string;
}

interface Props {
  lang: Lang;
  id?: string;
  class?: string;
}

const { lang, id = "como-funciona", class: className } = Astro.props;
const t = useTranslations(lang);

const steps = t('how_it_works.steps') as unknown as Step[];
const trustItems = t('how_it_works.trust_items') as unknown as string[];
const cta = t('how_it_works.cta') as string;
---

<section id={id} class={clsx("hiw", className)}>
  <div class="hiw-bg absolute inset-0 z-0">
    <Image
      src={bgImg}
      alt={t('how_it_works.bg_alt')}
      title={t('how_it_works.bg_alt')}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-how-overlay"></div>
  </div>

  <div class="si relative z-10">
    <div class="sh">
      <span class="st">{t('how_it_works.section_tag')}</span>
      <h2 class="text-white">{t('how_it_works.section_title')}</h2>
      <p class="text-white/60">{t('how_it_works.section_description')}</p>
    </div>

    <div class="stg">
      {steps.map((step, index) => (
        <StepCard
          number={index + 1}
          title={step.title}
          time={step.time}
          description={step.description}
          badge={step.badge}
        />
      ))}
    </div>

    <div class="tstrip">
      {trustItems.map((item) => (
        <span class="tstrip-item">{item}</span>
      ))}
    </div>

    <div style="text-align:center" class="mt-10">
      <a href="tel:+13053064511" class="bp">{cta}</a>
    </div>
  </div>
</section>