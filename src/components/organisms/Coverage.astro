---
import CoverageBadge from '../molecules/CoverageBadge.astro';
import Badge from '../atoms/Badge.astro';
import { MAP_EMBED_URL } from '../../constants/site';
import clsx from 'clsx';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';

interface Props {
  lang: Lang;
  class?: string;
}

const { lang, class: className } = Astro.props;
const t = useTranslations(lang);

const neighborhoods = t('neighborhoods') as string[];
const badgesData = t('badges') as any;

const coverageBadges = [
  {
    icon: 'check-circle',
    title: badgesData.licensed.title,
    subtitle: badgesData.licensed.subtitle,
    gradient: 'blue'
  },
  {
    icon: 'shield',
    title: badgesData.insured.title,
    subtitle: badgesData.insured.subtitle,
    gradient: 'blue'
  },
  {
    icon: 'clock',
    title: badgesData.emergency.title,
    subtitle: badgesData.emergency.subtitle,
    gradient: 'orange'
  },
  {
    icon: 'dollar-sign',
    title: badgesData.estimates.title,
    subtitle: badgesData.estimates.subtitle,
    gradient: 'green'
  }
];
---

<section class={clsx("bg-brand-navy py-16 relative overflow-hidden", className)}>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 tablet-lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
      
      <!-- Left: Map Container -->
      <div
        id="coverage-map-container"
        class="rounded-2xl overflow-hidden shadow-2xl border-2 border-glass-border order-2 tablet-lg:order-1"
      >
        <iframe
          id="coverage-map-frame"
          data-map-src={MAP_EMBED_URL}
          class="w-full h-[360px] block border-0"
          allowfullscreen=""
          loading="lazy"
          title={t('coverage.map_title')}
        ></iframe>
        <noscript>
          <iframe
            src={MAP_EMBED_URL}
            class="w-full h-[360px] block border-0"
            allowfullscreen=""
            loading="lazy"
            title={t('coverage.map_title')}
          ></iframe>
        </noscript>
      </div>

      <!-- Right: Content -->
      <div class="order-1 tablet-lg:order-2">
        <h2 class="text-3xl font-extrabold text-white mb-2 font-heading">
          {t('coverage.title')}
        </h2>
        <p class="text-[15px] text-white/50 mb-8">
          {t('coverage.subtitle')}
        </p>

        <!-- Badge Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          {coverageBadges.map((badge) => (
            <CoverageBadge 
              icon={badge.icon as any} 
              title={badge.title} 
              subtitle={badge.subtitle} 
              gradient={badge.gradient as any} 
            />
          ))}
        </div>

        <!-- Neighborhoods List -->
        <div class="flex flex-wrap gap-2">
          {neighborhoods.map((area) => (
            <Badge variant="tag" class="bg-brand-sky/10 border-brand-sky/20 text-brand-sky py-1.5 px-3">
              {area}
            </Badge>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const mapContainer = document.getElementById('coverage-map-container')
  const mapFrame = document.getElementById('coverage-map-frame')

  function loadCoverageMap() {
    if (!mapFrame) return
    if (mapFrame.getAttribute('src')) return
    const mapSrc = mapFrame.getAttribute('data-map-src')
    if (!mapSrc) return
    mapFrame.setAttribute('src', mapSrc)
  }

  if (mapContainer) {
    const observer = new IntersectionObserver(
      (entries) => {
        const [entry] = entries
        if (entry && entry.isIntersecting) {
          loadCoverageMap()
          observer.disconnect()
        }
      },
      { rootMargin: '320px 0px' }
    )

    observer.observe(mapContainer)
    mapContainer.addEventListener('pointerenter', loadCoverageMap, { once: true })
    mapContainer.addEventListener('touchstart', loadCoverageMap, { once: true })
    mapContainer.addEventListener('focusin', loadCoverageMap, { once: true })
  }
</script>
