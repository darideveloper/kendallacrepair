---
import clsx from 'clsx';
import Badge from '../atoms/Badge.astro';
import Button from '../atoms/Button.astro';
import HeroForm from '../molecules/HeroForm.astro';
import TrustItem from '../molecules/TrustItem.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section class={clsx("hero relative min-h-[620px] flex items-center overflow-hidden", className)}>
  <div class="hero-bg absolute inset-0 z-0">
    <img
      src="/ui-design/foto-trane-single.jpg"
      alt="AC Repair Kendall"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-hero-overlay"></div>
  </div>
  
  <div class="hero-inner max-w-[1200px] mx-auto px-6 py-10 lg:py-[60px] grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-[60px] items-center relative z-[2] w-full">
    <div class="hero-content animate-fade-in-up">
      <Badge class="mb-6">
        Tecnicos disponibles ahora en Kendall
      </Badge>
      
      <h1 class="font-heading text-[32px] md:text-[42px] lg:text-[52px] font-extrabold text-white leading-[1.1] mb-5">
        Reparacion de AC en Kendall<br />
        <span class="bg-gradient-to-r from-[#fd7e14] to-[#f76707] bg-clip-text text-transparent">
          Rapido. Confiable. Hoy Mismo.
        </span>
      </h1>
      
      <p class="text-[18px] text-white/70 leading-relaxed mb-8 max-w-[520px] font-body">
        Conectamos a los duenos de casa en Kendall con tecnicos de AC licenciados y asegurados — servicio el mismo dia, estimados gratis.
      </p>
      
      <div class="hero-ctas flex flex-wrap gap-3.5 mb-10">
        <Button href="tel:+13055551234" variant="primary">
          <svg
            slot="before"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
          </svg>
          Llama Ahora — Estimado Gratis
        </Button>
        
        <Button href="#formulario" variant="secondary">
          Solicita Cotizacion Online
        </Button>
      </div>
      
      <div class="trust-row flex flex-wrap gap-6">
        <TrustItem icon="🛡️">Licenciado y Asegurado</TrustItem>
        <TrustItem icon="🕒">Servicio Mismo Dia</TrustItem>
        <TrustItem icon="⭐">Estimados Gratis</TrustItem>
      </div>
    </div>
    
    <HeroForm id="formulario" />
  </div>
</section>
