---
import { Image } from 'astro:assets';
import clsx from 'clsx';
import { SITE } from '../../constants/site';
import Button from '../atoms/Button.astro';
import Icon from '../atoms/Icon.astro';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';
import bgImage from '../../assets/images/hero/foto-trane-single.jpg';

interface Props {
  lang: Lang;
  class?: string;
}

const { lang, class: className } = Astro.props;
const t = useTranslations(lang);
---

<section class={clsx("relative py-20 overflow-hidden text-center bg-brand-navy", className)}>
  <div class="absolute inset-0 z-0">
    <Image 
      src={bgImage} 
      alt={t('final_cta.bg_alt')}
      class="w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-how-overlay"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6">
    <h2 class="text-[clamp(28px,4vw,42px)] font-extrabold text-white mb-4 leading-tight font-heading animate-fade-in-up" set:html={t('final_cta.title')}>
    </h2>
    
    <a 
      href={`tel:${SITE.phone.value}`}
      class="text-[clamp(32px,5vw,56px)] font-extrabold text-white mb-8 block transition-colors duration-300 hover:text-brand-orange hover:no-underline font-heading animate-fade-in-up"
      style="animation-delay: 0.1s;"
    >
      {SITE.phone.display}
    </a>
    
    <p class="text-lg text-white/60 mb-9 animate-fade-in-up" style="animation-delay: 0.2s;" set:html={t('final_cta.benefits')}>
    </p>

    <div class="flex flex-wrap justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
      <Button href={`tel:${SITE.phone.value}`}>
        <Icon name="phone" size={20} slot="before" />
        {t('ui.call_now')}
      </Button>
      <Button href="#formulario" variant="secondary">
        {t('hero.cta_online')}
      </Button>
    </div>
  </div>
</section>
