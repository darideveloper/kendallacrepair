---
import FAQItem from '../molecules/FAQItem.astro';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const faqItems = t('faq.items') as any as { question: string; answer: string }[];
---

<section id="faq" class="faq py-20 bg-white">
  <div class="section-inner max-w-[1200px] mx-auto px-6">
    <div class="section-header text-center mb-14 animate-fade-in-up">
      <span class="section-tag inline-block bg-blue-50 text-brand-blue px-4 py-1.5 rounded-full text-[13px] font-semibold mb-4">
        {t('faq.section_tag')}
      </span>
      <h2 class="text-[28px] md:text-[34px] lg:text-[40px] font-extrabold text-gray-900 mb-3 font-heading">
        {t('faq.section_title')}
      </h2>
    </div>
    <div class="faq-list max-w-[760px] mx-auto">
      {faqItems.map((item) => (
        <FAQItem question={item.question} answer={item.answer} />
      ))}
    </div>
  </div>
</section>
