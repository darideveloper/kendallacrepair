---
import FAQItem from '../molecules/FAQItem.astro';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';
import { SITE } from '../../constants/site';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const faqItems = t('faq.items') as any as { question: string; answer: string }[];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
<section id="faq" class="faq py-20 bg-white">
  <div class="section-inner max-w-[1200px] mx-auto px-6">
    <div class="section-header text-center mb-14 animate-fade-in-up">
      <span class="section-tag inline-block bg-blue-50 text-brand-blue px-4 py-1.5 rounded-full text-[13px] font-semibold mb-4">
        {t('faq.section_tag')}
      </span>
      <h2 class="text-[28px] md:text-[34px] lg:text-[40px] font-extrabold text-gray-900 mb-3 font-heading">
        {t('faq.section_title')}
      </h2>
    </div>
    <div class="faq-list max-w-[760px] mx-auto" itemscope itemtype="https://schema.org/FAQPage">
      {faqItems.map((item, i) => (
        <FAQItem question={item.question} answer={item.answer} open={i === 0} />
      ))}
    </div>
    <div class="faq-cta text-center mt-12 p-8 bg-blue-50 rounded-xl">
      <p class="text-[15px] text-gray-800">
        {t('faq.cta')}{' '}
        <a href={`tel:${SITE.phone.value}`} class="text-brand-blue font-bold no-underline">
          {t('faq.cta_phone')}
        </a>{' '}
        {t('faq.or')}{' '}
        <a href={`https://wa.me/${SITE.whatsapp.phone}`} target="_blank" class="text-brand-blue font-bold no-underline">
          {t('faq.cta_whatsapp')}
        </a>
      </p>
    </div>
  </div>
</section>
