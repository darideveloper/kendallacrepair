---
import clsx from 'clsx';

interface Props extends astroHTML.JSX.TextareaHTMLAttributes {
  label?: string;
}

const { label, id, class: className, required, ...rest } = Astro.props;
const elementId = id || `textarea-${Math.random().toString(36).substr(2, 9)}`;
---

<div class={clsx("flex flex-col gap-1.5", className)}>
  {label && (
    <label for={elementId} class="text-[13px] font-semibold text-[#495057]">
      {label} {required && <span class="text-brand-red">*</span>}
    </label>
  )}
  <textarea
    id={elementId}
    required={required}
    class="w-full px-4 py-3.5 bg-[#F8F9FA] border-2 border-[#E9ECEF] rounded-lg font-body text-base text-[#343A40] transition-all outline-none focus:border-brand-blue focus:bg-white focus:ring-3 focus:ring-brand-blue/12 placeholder:text-[#868E96] resize-y min-h-[80px]"
    {...rest}
  ></textarea>
</div>
