---
import Layout from '../../layouts/Layout.astro';
import Button from '../atoms/Button.astro';
import Icon from '../atoms/Icon.astro';
import { SITE } from '../../constants/site';
import { useTranslations, getLocalizedPath } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';
import type { PageKey } from '../../lib/i18n/routes';

interface Props {
  lang: Lang;
  pageKey: PageKey;
}

const { lang, pageKey } = Astro.props;
const t = useTranslations(lang);
---

<Layout {lang} {pageKey}>
  <section class="min-h-[80vh] flex items-center justify-center px-6 py-20 bg-gray-50">
    <div class="max-w-2xl w-full bg-white rounded-[32px] p-8 md:p-16 shadow-[0_20px_60px_rgba(0,0,0,0.08)] text-center animate-fade-in-up">
      <div class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-8">
        <Icon name="check" size={48} />
      </div>
      
      <h1 class="text-3xl md:text-5xl font-heading font-extrabold text-[#0C2340] mb-6 leading-tight">
        {t('pages.thank_you.h1')}
      </h1>
      
      <p class="text-lg md:text-xl text-[#495057] mb-10 font-body leading-relaxed" set:html={t('pages.thank_you.message')}>
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={getLocalizedPath('home', lang)} variant="navy" class="px-10">
          {t('pages.thank_you.back_home')}
        </Button>
        <Button href={`tel:${SITE.phone.value}`} variant="primary" class="px-10">
          <Icon name="phone" size={20} slot="before" />
          {t('pages.thank_you.urgent_help')}
        </Button>
      </div>
      
      <div class="mt-16 pt-8 border-t border-gray-100">
        <p class="text-sm text-[#868E96]">
          {t('site.name')} — {t('ui.emergency_call_banner')}
        </p>
      </div>
    </div>
  </section>
</Layout>
