---
import { Image } from 'astro:assets';
import clsx from 'clsx';
import { SITE } from '../../constants/site';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  icon: string;
  ctaText?: string;
  class?: string;
}

const { title, description, image, icon, ctaText = "Llamar", class: className } = Astro.props;
---

<div class={clsx("sc", className)}>
  <Image 
    src={image} 
    alt={title} 
    title={title}
    class="si2" 
    width={400}
    height={225}
    loading="lazy"
    decoding="async"
  />

  <div class="sb">
    <h3>{icon} {title}</h3>
    <p>
      {description}
    </p>
    <a href={`tel:${SITE.phone.value}`} class="sc-cta">
      {ctaText} {SITE.phone.display} →
    </a>
  </div>
</div>
