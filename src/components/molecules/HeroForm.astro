---
import clsx from 'clsx';
import Button from '../atoms/Button.astro';
import Input from '../atoms/Input.astro';
import Textarea from '../atoms/Textarea.astro';
import { useTranslations, getLocalizedPath } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';

interface Props {
  lang: Lang;
  class?: string;
  id?: string;
}

const { lang, class: className, id } = Astro.props;
const t = useTranslations(lang);

const endpoint = import.meta.env.CONTACT_FORM_ENDPOINT;
const user = import.meta.env.CONTACT_FORM_USER;
const apiKey = import.meta.env.CONTACT_FORM_API_KEY;
const siteUrl = import.meta.env.SITE_URL || Astro.site?.origin || 'http://localhost:4321';
const redirectPath = getLocalizedPath('thank_you', lang);
const redirectUrl = `${siteUrl}${redirectPath}`;
---

<div id={id} class={clsx(
  "hero-form-card relative overflow-hidden bg-white rounded-[20px] p-9 shadow-[0_20px_60px_rgba(0,0,0,0.15)] animate-fade-in-up",
  "before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-1 before:bg-gradient-to-r before:from-[#f76707] before:to-brand-blue",
  className
)}>
  <div class="form-header text-center mb-7">
    <h3 class="text-[22px] font-extrabold text-[#212529] mb-1.5 font-heading">{t('forms.hero.title')}</h3>
    <p class="text-sm text-[#868e96]">{t('forms.hero.subtitle')}</p>
  </div>

  <form 
    id="hero-contact-form" 
    class="flex flex-col gap-4"
    action={endpoint}
    method="POST"
    enctype="multipart/form-data"
  >
    <!-- Hidden fields for the backend -->
    <input type="hidden" name="api_key" value={apiKey} />
    <input type="hidden" name="user" value={user} />
    <input type="hidden" name="subject" value={`${t('site.name')} - ${t('forms.hero.subject')}`} />
    <input type="hidden" name="redirect" value={redirectUrl} />

    <Input 
      label={t('forms.hero.name_label')} 
      name="name" 
      placeholder={t('forms.hero.name_placeholder')} 
      required
    />
    <Input 
      label={t('forms.hero.phone_label')} 
      name="phone" 
      type="tel" 
      placeholder="(305) 000-0000" 
      required 
    />
    <Input 
      label={t('forms.hero.email_label')} 
      name="email" 
      type="email" 
      placeholder="tu@email.com" 
    />
    <Textarea 
      label={t('forms.hero.message_label')} 
      name="message" 
      placeholder={t('forms.hero.message_placeholder')} 
      required
    />

    <Button type="submit" class="w-full mt-2" variant="primary">
      {t('forms.hero.submit')} &rarr;
    </Button>
    
    <p class="text-center text-[12px] text-[#adb5bd] mt-3">
      {t('forms.hero.privacy_note')}
    </p>
  </form>
</div>
