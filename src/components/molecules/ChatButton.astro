---
import clsx from 'clsx';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={clsx("chat-container fixed bottom-6 right-6 z-[9997] md:bottom-8 md:right-8", className)}>
  <button 
    id="chat-toggle"
    class="float-chat w-14 h-14 rounded-full bg-brand-blue text-white flex items-center justify-center shadow-[0_4px_20px_rgba(26,111,175,0.35)] transition-transform hover:scale-110 animate-fade-in-up relative"
    title="Chat con IA"
  >
    <span class="chat-badge absolute -top-0.5 -right-0.5 w-4 h-4 bg-brand-orange rounded-full border-2 border-white animate-pulse-custom"></span>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
  </button>

  <div id="chat-popup" class="chat-popup fixed bottom-24 right-6 z-[10000] w-[370px] bg-white rounded-[20px] shadow-[0_20px_60px_rgba(0,0,0,0.15)] overflow-hidden scale-90 translate-y-5 opacity-0 pointer-events-none transition-all duration-300 origin-bottom-right sm:left-4 sm:right-4 sm:w-auto">
    <div class="chat-hdr bg-[#0c2340] p-5 flex items-center justify-between">
      <div class="chat-hdr-info flex items-center gap-3">
        <div class="chat-hdr-avatar w-10 h-10 rounded-full bg-brand-blue-grad flex items-center justify-center text-lg">❄️</div>
        <div class="chat-hdr-text">
          <strong class="block text-white text-[15px] font-heading">Ana - Asistente AC</strong>
          <span class="text-xs text-white/60">En linea • Respuesta instantanea</span>
        </div>
      </div>
      <button id="chat-close" class="chat-close bg-white/10 border-none color-white w-8 h-8 rounded-full cursor-pointer flex items-center justify-center text-white hover:bg-white/20">
        &times;
      </button>
    </div>
    <div class="chat-body p-5 h-[300px] overflow-y-auto bg-[#f8f9fa]">
      <div class="flex gap-2 mb-3">
        <div class="chat-bubble bg-white p-4 rounded-[16px_16px_16px_4px] text-sm leading-relaxed text-[#495057] shadow-[0_1px_3px_rgba(0,0,0,0.08)] max-w-[280px] animate-fade-in-up">
          Hola! 👋 Tu AC no esta enfriando? Podemos tener un tecnico en tu zona de Kendall <strong>hoy mismo</strong>.<br><br>Cual es el problema que estas teniendo?
        </div>
      </div>
    </div>
    <div class="chat-input-area p-4 border-t border-[#e9ecef] flex gap-2.5 bg-white">
      <input type="text" class="chat-input flex-1 px-3.5 py-2.5 border border-[#e9ecef] rounded-full text-sm outline-none focus:border-brand-sky" placeholder="Escribe tu mensaje..." />
      <button class="chat-send w-10 h-10 rounded-full bg-brand-blue text-white flex items-center justify-center cursor-pointer hover:bg-brand-blue/90 transition-colors">
        ➤
      </button>
    </div>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById('chat-toggle');
  const closeBtn = document.getElementById('chat-close');
  const popup = document.getElementById('chat-popup');

  function toggleChat() {
    if (popup) {
      popup.classList.toggle('scale-100');
      popup.classList.toggle('translate-y-0');
      popup.classList.toggle('opacity-100');
      popup.classList.toggle('pointer-events-all');
    }
  }

  toggleBtn?.addEventListener('click', toggleChat);
  closeBtn?.addEventListener('click', toggleChat);

  // Auto-open after 15 seconds if not already opened
  setTimeout(() => {
    if (popup && !popup.classList.contains('opacity-100')) {
      toggleChat();
    }
  }, 15000);
</script>

<style>
  .pointer-events-all {
    pointer-events: all;
  }
</style>
