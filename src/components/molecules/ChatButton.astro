---
import clsx from 'clsx'
import { useTranslations } from '../../lib/i18n/utils'
import type { Lang } from '../../lib/i18n/ui'

interface Props {
  lang: Lang
  class?: string
}

const { lang, class: className } = Astro.props
const t = useTranslations(lang)
---

<div
  class={clsx(
    'chat-container fixed bottom-20 right-6 z-[9997] sm:bottom-8 md:right-8',
    className,
  )}
>
  <button
    id='chat-toggle'
    class='float-chat w-14 h-14 rounded-full bg-brand-blue text-white flex items-center justify-center shadow-[0_4px_20px_rgba(26,111,175,0.35)] transition-transform hover:scale-110 animate-fade-in-up relative'
    title={t('ui.chat_with_ai')}
  >
    <span
      class='chat-badge absolute -top-0.5 -right-0.5 w-4 h-4 bg-brand-orange rounded-full border-2 border-white animate-pulse-custom'
    ></span>
    <svg
      width='24'
      height='24'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
    >
      <path d='M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z'></path>
    </svg>
  </button>

  <div
    id='chat-popup'
    class='chat-popup absolute bottom-[90px] right-0 z-[10000] w-[350px] max-w-[calc(100vw-3rem)] h-[550px] max-h-[calc(100vh-180px)] flex flex-col bg-white rounded-[20px] shadow-[0_20px_60px_rgba(0,0,0,0.15)] overflow-hidden scale-90 translate-y-5 opacity-0 pointer-events-none transition-all duration-300 origin-bottom-right'
  >
    <iframe
      src='https://n8n.apps.darideveloper.com/webhook/1da5e766-56e7-4e76-8cb4-879be56bfdd2/chat'
      width='100%'
      height='100%'
      style='border: none;'
      title='Chat con IA'
      class='mb-2'
    ></iframe>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById('chat-toggle')
  const popup = document.getElementById('chat-popup')

  function toggleChat() {
    if (popup) {
      popup.classList.toggle('scale-100')
      popup.classList.toggle('translate-y-0')
      popup.classList.toggle('opacity-100')
      popup.classList.toggle('pointer-events-all')
    }
  }

  toggleBtn?.addEventListener('click', toggleChat)

  // Auto-open after 15 seconds if not already opened
  setTimeout(() => {
    if (popup && !popup.classList.contains('opacity-100')) {
      toggleChat()
    }
  }, 5000)
</script>

<style>
  .pointer-events-all {
    pointer-events: all;
  }
</style>
