---
import { Image } from 'astro:assets';
import clsx from 'clsx';
import type { Testimonial } from '../../constants/site';
import { useTranslations } from '../../lib/i18n/utils';
import type { Lang } from '../../lib/i18n/ui';

interface Props extends Testimonial {
  class?: string;
  lang: Lang;
}

const { quote, author, location, initials, image, date, isVerified, englishSubtext, lang, class: className } = Astro.props;
const t = useTranslations(lang);
---

<div class={clsx(
  "bg-white rounded-xl p-8 shadow-[0_1px_3px_rgba(0,0,0,0.08)] border border-gray-200 transition-all duration-300 hover:shadow-[0_4px_16px_rgba(0,0,0,0.1)] hover:-translate-y-0.5",
  className
)}>
  <div class="text-[#f59f00] text-[18px] mb-4 tracking-[2px]">
    &starf;&starf;&starf;&starf;&starf;
  </div>
  <blockquote class="text-[15px] text-gray-600 leading-[1.7] mb-2 italic font-body">
    &ldquo;{quote}&rdquo;
  </blockquote>
  {englishSubtext && (
    <div class="text-[12px] text-gray-400 mb-4 italic font-body">
      (English: {englishSubtext})
    </div>
  )}
  <div class="flex items-center gap-3 mb-3">
    <div class="w-11 h-11 rounded-full bg-brand-blue-grad overflow-hidden shrink-0 flex items-center justify-center font-bold text-[16px] font-heading">
      {image ? (
        <Image 
          src={image} 
          alt={author} 
          title={author}
          width={44} 
          height={44} 
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="text-white">{initials}</span>
      )}
    </div>
    <div>
      <strong class="block text-[14px] text-gray-800 font-heading">{author}</strong>
      <span class="text-[13px] text-gray-500 font-body">{location}{date ? ` \u2022 ${date}` : ''}</span>
    </div>
  </div>
  {isVerified && (
    <div class="inline-flex items-center gap-1 text-[12px] text-[#4285F4] font-semibold">
      ✅ {t('testimonials.verified_text')}
    </div>
  )}
</div>
