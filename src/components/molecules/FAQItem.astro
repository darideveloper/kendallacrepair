---
import clsx from 'clsx';

interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="faq-item group border-b border-gray-200 py-6">
  <button
    class="faq-question flex justify-between items-center cursor-pointer w-full text-left font-heading text-[17px] font-semibold text-gray-800 gap-4 outline-none"
    onclick="this.parentElement.classList.toggle('open')"
  >
    {question}
    <span class="chevron w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0 transition-colors duration-300 text-sm text-gray-500 group-[.open]:bg-blue-100 group-[.open]:text-brand-blue group-[.open]:rotate-180">
      ▼
    </span>
  </button>
  <div class="faq-answer max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out group-[.open]:max-h-[200px] group-[.open]:pt-4">
    <p class="text-[15px] text-gray-500 leading-relaxed font-body">
      {answer}
    </p>
  </div>
</div>
