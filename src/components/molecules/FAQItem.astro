---
import clsx from 'clsx';

interface Props {
  question: string;
  answer: string;
  open?: boolean;
}

const { question, answer, open = false } = Astro.props;
---

<div
  class={clsx('faq-item group border-b border-gray-200 py-6', { open })}
  itemscope
  itemprop="mainEntity"
  itemtype="https://schema.org/Question"
>
  <div
    class="faq-q flex justify-between items-center cursor-pointer text-[17px] font-semibold text-gray-800 gap-4 font-heading"
    onclick="this.parentElement.classList.toggle('open')"
  >
    <span itemprop="name">{question}</span>
    <span class="chv w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0 transition-colors duration-300 text-sm text-gray-500 group-[.open]:bg-blue-100 group-[.open]:text-brand-blue group-[.open]:rotate-180">
      ▼
    </span>
  </div>
  <div
    class="faq-a max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out group-[.open]:max-h-[300px] group-[.open]:pt-4"
    itemscope
    itemprop="acceptedAnswer"
    itemtype="https://schema.org/Answer"
  >
    <p class="text-[15px] text-gray-500 leading-relaxed font-body" itemprop="text">
      {answer}
    </p>
  </div>
</div>
