---
import clsx from 'clsx';

interface Props {
  icon: string;
  class?: string;
}

const { icon, class: className } = Astro.props;
---

<div class={clsx("flex items-center gap-2 text-white/60 text-sm font-medium", className)}>
  <div class="w-8 h-8 bg-brand-sky/15 rounded-lg flex items-center justify-center text-base">
    {icon}
  </div>
  <slot />
</div>
