---
import clsx from 'clsx';

interface Props {
  number: number;
  title: string;
  description: string;
  time?: string;
  badge?: string;
  class?: string;
}

const { number, title, description, time, badge, class: className } = Astro.props;
---

<div class={clsx("stc", className)}>
  <div class="stn">{number}</div>
  <h3 class="text-[20px] font-bold text-white mb-2.5 font-heading">{title}</h3>
  {time && <div class="time">{time}</div>}
  <p class="text-[15px] text-white/60 leading-relaxed font-body">{description}</p>
  {badge && <div class="wbadge">{badge}</div>}
</div>
